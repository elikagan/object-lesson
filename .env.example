# Supabase — public values (safe to commit; baked into client bundle)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — server-only (NEVER expose to browser)
SUPABASE_SERVICE_ROLE_KEY=

# Square (server-only)
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_WEBHOOK_SIGNATURE_KEY=

# Resend (server-only)
RESEND_API_KEY=

# Gemini AI (server-only)
GEMINI_API_KEY=
